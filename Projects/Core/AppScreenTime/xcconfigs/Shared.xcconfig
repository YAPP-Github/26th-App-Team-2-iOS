// Debug 환경 설정
OTHER_SWIFT_FLAGS[config=Debug][sdk=*] = $(inherited) -DDEBUG

// Release 환경 설정
OTHER_SWIFT_FLAGS[config=Release][sdk=*] = $(inherited) -DRELEASE 
